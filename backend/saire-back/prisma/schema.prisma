// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Refrigerador {
  id            Int              @id @default(autoincrement())
  modelo        String
  createdAt     DateTime         @default(now())

  especificacao Especificacoes?
  documentos    Documento[]
}

model Especificacoes {
  id                       Int    @id @default(autoincrement())
  refrigeradorId           Int    @unique

  voltagem                 Int?
  frequencia               Int?
  corrente                 Float?
  correnteBloqueadoY       Float?
  correnteBloqueadoYY      Float?
  volumeDeslocamento       Float?
  rotacao                  Int?

  refrigerador Refrigerador @relation(fields: [refrigeradorId], references: [id])
}

model Documento {
  id               Int       @id @default(autoincrement())
  refrigeradorId   Int

  tipo             TipoDocumento
  url              String
  nomeArquivo      String?

  createdAt        DateTime  @default(now())

  refrigerador Refrigerador @relation(fields: [refrigeradorId], references: [id])

  @@index([refrigeradorId])
  @@index([tipo])
}

enum TipoDocumento {
  manual
  montagem
}