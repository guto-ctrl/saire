// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Compressor {
  id            Int              @id @default(autoincrement())
  modelo        String
  marca         String
  createdAt     DateTime         @default(now())

  voltagem                 Int?
  frequencia               Int?
  corrente                 Float?
  correnteBloqueadoY       Float?
  correnteBloqueadoYY      Float?
  volumeDeslocamento       Float?
  rotacao                  Int?

  checklists    Checklist[]
  etiquetas     Etiqueta[]
}

model Checklist {
  id            Int      @id @default(autoincrement())
  compressorId  Int

  montador      String?
  data          DateTime?
  observacao    String?

  url           String?  // opcional (foto do papel)
  nomeArquivo   String?

  createdAt     DateTime @default(now())

  compressor Compressor @relation(fields: [compressorId], references: [id])
  etiqueta Etiqueta[]
  
  @@index([compressorId])
}

model Etiqueta {
  id               Int      @id @default(autoincrement())
  compressorId     Int
  checklistId      Int

  numeroSerie      String @unique
  qrCodeUrl        String?

  createdAt        DateTime @default(now())

  compressor Compressor @relation(fields: [compressorId], references: [id])
  checklist  Checklist  @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([compressorId])
}