// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Compressor {
  id            Int              @id @default(autoincrement())
  modelo        String
  createdAt     DateTime         @default(now())

  especificacao Especificacoes?
  documentos    Documento[]
  etiquetas     Etiqueta[]
}

model Especificacoes {
  id                       Int    @id @default(autoincrement())
  compressorId             Int    @unique

  voltagem                 Int?
  frequencia               Int?
  corrente                 Float?
  correnteBloqueadoY       Float?
  correnteBloqueadoYY      Float?
  volumeDeslocamento       Float?
  rotacao                  Int?

  compressor Compressor @relation(fields: [compressorId], references: [id])
}

model Documento {
  id               Int       @id @default(autoincrement())
  compressorId     Int

  tipo             TipoDocumento
  url              String
  nomeArquivo      String?

  createdAt        DateTime  @default(now())

  compressor Compressor @relation(fields: [compressorId], references: [id])

  @@index([compressorId])
  @@index([tipo])
}

model Etiqueta {
  id               Int      @id @default(autoincrement())
  compressorId     Int

  numeroSerie      String
  qrCodeUrl        String?

  createdAt        DateTime @default(now())

  compressor Compressor @relation(fields: [compressorId], references: [id])

  @@index([compressorId])
}

enum TipoDocumento {
  manual
  montagem
}